{
  "name": "change-behaviour-today",
  "version": "0.1.0",
  "description": "Sarah's website",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch & vite preview",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.js test/content.test.js",
    "test:build": "vitest run --config vitest.config.js test/build.test.js",
    "lint": "eslint . && prettier --check . && stylelint 'src/**/*.scss'",
    "format": "prettier --write .",
    "test:a11y": "vitest run --config vitest.config.js test/accessibility.test.js",
    "validate:html": "html-validate 'dst/**/*.html'",
    "validate:links": "lychee --config lychee.toml 'dst/**/*.html'",
    "lighthouse": "lhci autorun",
    "check": "npm test && stylelint 'src/**/*.scss' && npm run build && npm run test:build && npm run validate:html && npm run test:a11y && npm run validate:links && npm run lighthouse"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "autoprefixer": "^10.4.16",
    "axe-core": "^4.12.1",
    "cssnano": "^8.0.2",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "html-validate": "^10.9.0",
    "js-yaml": "^4.2.0",
    "jsdom": "^29.1.1",
    "lighthouse": "^12.8.2",
    "postcss": "^8.4.31",
    "postcss-cli": "^11.0.1",
    "postcss-font-magician": "^4.0.0",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^11.3.0",
    "prettier": "^3.8.4",
    "prettier-plugin-handlebars": "^0.0.1",
    "sass": "^1.69.3",
    "sharp": "^0.35.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "terser": "^5.21.0",
    "vite": "^8.0.16",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-handlebars": "^2.0.3",
    "vitest": "^4.1.8"
  }
}
